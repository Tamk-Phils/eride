# Supabase connection (get from: Supabase Dashboard → Settings → Database → Connection string → URI)
DATABASE_URL="postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres"

# Supabase anon/service keys (for Realtime subscriptions on the client)
SUPABASE_URL="https://[YOUR-PROJECT-REF].supabase.co"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# JWT
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
PORT=5000
NODE_ENV=development

# NkwaPay (sandbox from pay.mynkwa.com)
NKWA_BASE_URL="https://api.mynkwa.com"
NKWA_API_KEY="your-nkwapay-sandbox-api-key"
